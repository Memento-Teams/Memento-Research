# OpenRouter API (used as OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model (used if not overridden per-agent in founding_employees.yaml)
DEFAULT_LLM_MODEL=openai/gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
HOT_RELOAD=true

# OpenSandbox
SANDBOX_ENABLED=false
SANDBOX_SERVER_URL=http://localhost:8080
SANDBOX_DEFAULT_IMAGE=opensandbox/code-interpreter:v1.0.1
SANDBOX_TIMEOUT_SECONDS=120

# Talent Market
TALENT_MARKET_URL=https://api.one-man-company.com/mcp/sse
TALENT_MARKET_API_KEY=
TALENT_MARKET_USE_AI_SEARCH=false
TALENT_MARKET_MODE=local

# ---------------------------------------------------------------------------
# Auth / Login  (verification-code login → external backend → JWT cookie)
# ---------------------------------------------------------------------------
# The login gate (src/onemancompany/api/auth_gate.py) sits in front of the whole
# site and is what enforces per-user isolation (each logged-in user only sees
# their own projects / pipelines / live events). It is OFF by default in code,
# so local dev, CI and headless runs stay open with zero setup.
#
# DEPLOYMENTS SHOULD TURN THIS ON. To enable, set AUTH_ENABLED=1 AND point
# AUTH_BACKEND at a real auth service — enabling it WITHOUT a backend locks the
# whole site (login forwards to an empty URL → 502, nobody can get in).
AUTH_ENABLED=0
# Base URL of the external auth service that issues the verification code + JWT.
# REQUIRED whenever AUTH_ENABLED=1. Leave empty for local/open mode.
AUTH_BACKEND=
# Let requests originating on the server itself (127.0.0.1/::1) skip the login
# gate — needed so server-side automation (headless full-auto pipeline runs)
# keeps working when AUTH_ENABLED=1. External clients are unaffected.
OMC_TRUST_LOCALHOST=0
# The JWT is stored in an HttpOnly, same-origin cookie named "mmt_at" (no config
# needed; listed here for reference).
