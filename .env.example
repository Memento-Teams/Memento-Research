# OpenRouter API (used as OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model (used if not overridden per-agent in founding_employees.yaml)
DEFAULT_LLM_MODEL=openai/gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
HOT_RELOAD=true

# OpenSandbox
SANDBOX_ENABLED=false
SANDBOX_SERVER_URL=http://localhost:8080
SANDBOX_DEFAULT_IMAGE=opensandbox/code-interpreter:v1.0.1
SANDBOX_TIMEOUT_SECONDS=120

# Talent Market
TALENT_MARKET_URL=https://api.one-man-company.com/mcp/sse
TALENT_MARKET_API_KEY=
TALENT_MARKET_USE_AI_SEARCH=false
TALENT_MARKET_MODE=local

# Stage Eval Agent (advisory per-stage checklist reports). Set false to disable.
STAGE_EVAL_ENABLED=true

# cspaper.org Agentic Review (optional Stage 8/9 external paper review).
# Leave CSPAPER_API_KEY empty to use the built-in review_template_en.md fallback.
# The poll path is configurable because cspaper's "Check Results" endpoint is
# not publicly documented — set CSPAPER_POLL_PATH once you confirm it.
CSPAPER_API_KEY=
CSPAPER_AGENT_ID=NeurIPS_main_2025_1
# CSPAPER_POLL_PATH=/api/platform/review/{job_id}
